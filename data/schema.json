{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OverStand Ontology",
  "version": "2.0.0",
  "description": "Ontología v2: Actor + Evento como nodos. Relaciones como aristas con metadatos. Noticias solo en SQL.",

  "graph": {
    "name": "overstanding",
    "nodes": {
      "Actor": {
        "description": "Entidad que participa en eventos: persona, organización, lugar u objeto.",
        "properties": {
          "id":          { "type": "string", "description": "Identificador único kebab-case.", "primary": true },
          "name":        { "type": "string", "description": "Nombre legible para visualización." },
          "type":        { "type": "string", "enum": ["Person", "Organization", "Location", "Object"], "description": "Clasificación." },
          "description": { "type": "string", "description": "Descriptor breve en español." }
        }
      },
      "Evento": {
        "description": "Hecho noticioso discreto. Centro gravitacional del grafo.",
        "properties": {
          "id":              { "type": "string", "description": "kebab-case descriptivo (ej: 'disculpa-rai-bobsled-israel').", "primary": true },
          "name":            { "type": "string", "description": "Nombre legible en español del hecho." },
          "event_type":      { "type": "string", "$ref": "#/event_types" },
          "date":            { "type": "string", "format": "date", "description": "Fecha del evento (YYYY-MM-DD)." },
          "is_disputed":     { "type": "boolean", "default": false },
          "evidence_quote":  { "type": "string", "description": "Cita textual en idioma original de la fuente." },
          "source":          { "type": "string", "description": "Nombre de la fuente que reporta." },
          "source_url":      { "type": "string", "format": "uri" }
        }
      }
    },
    "edges": {
      "PARTICIPA": {
        "from": "Actor",
        "to": "Evento",
        "description": "El actor participa en este evento. El rol describe cómo.",
        "properties": {
          "role": { "type": "string", "description": "Verbo que describe la participación: 'se disculpa', 'ataca', 'sanciona', 'declara'." }
        },
        "visual": { "color": "#2980B9", "style": "arrow", "width": 2, "force_distance": 80 }
      },
      "CAUSA": {
        "from": "Evento",
        "to": "Evento",
        "description": "Un evento causa o desencadena otro.",
        "visual": { "color": "#8E44AD", "style": "arrow", "width": 3, "force_distance": 150 }
      },
      "CONTRADICE": {
        "from": "Evento",
        "to": "Evento",
        "description": "Dos eventos de distintas fuentes se contradicen sobre el mismo hecho.",
        "properties": {
          "tension_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "analysis":      { "type": "string" },
          "detected_by":   { "type": "string" }
        },
        "visual": { "color": "#E74C3C", "style": "solid", "width": 5, "force_distance": 300 }
      },
      "COMPLEMENTA": {
        "from": "Evento",
        "to": "Evento",
        "description": "Dos eventos de distintas fuentes se refuerzan mutuamente.",
        "visual": { "color": "#27AE60", "style": "dashed", "width": 2, "force_distance": 50 }
      },
      "PERTENECE_A": {
        "from": "Actor",
        "to": "Actor",
        "description": "Relación estructural (presidente de, miembro de).",
        "visual": { "color": "#7F8C8D", "style": "solid", "width": 1, "force_distance": 60 }
      },
      "UBICADO_EN": {
        "from": "Actor",
        "to": "Actor",
        "description": "Relación geográfica.",
        "visual": { "color": "#7F8C8D", "style": "dashed", "width": 1, "force_distance": 60 }
      }
    }
  },

  "sql": {
    "news_raw": {
      "description": "Tabla relacional para noticias. Fuente de verdad para el feed. No entra al grafo.",
      "columns": {
        "id":            { "type": "serial", "primary": true },
        "source_name":   { "type": "text" },
        "source_lang":   { "type": "text" },
        "source_region": { "type": "text" },
        "title":         { "type": "text" },
        "link":          { "type": "text", "unique": true },
        "description":   { "type": "text" },
        "pub_date":      { "type": "text" },
        "ingested_at":   { "type": "timestamptz", "default": "NOW()" },
        "processed":     { "type": "boolean", "default": false }
      }
    }
  },

  "event_types": [
    { "id": "CAMBIO_LIDERAZGO",     "label": "Cambio de liderazgo" },
    { "id": "PROMULGACION_NORMA",    "label": "Promulgación de norma" },
    { "id": "PROTESTA_SOCIAL",       "label": "Protesta social" },
    { "id": "RUPTURA_DIPLOMATICA",   "label": "Ruptura diplomática" },
    { "id": "ACCION_ARMADA",         "label": "Acción armada" },
    { "id": "AMENAZA_COERCION",      "label": "Amenaza o coerción" },
    { "id": "INCAUTACION_DETENCION", "label": "Incautación o detención" },
    { "id": "ACUERDO_PAZ",           "label": "Acuerdo de paz" },
    { "id": "ADQUISICION_FUSION",    "label": "Adquisición o fusión" },
    { "id": "SANCION_ECONOMICA",     "label": "Sanción económica" },
    { "id": "LANZAMIENTO_PRODUCTO",  "label": "Lanzamiento de producto" },
    { "id": "QUIEBRA_INSOLVENCIA",   "label": "Quiebra o insolvencia" },
    { "id": "DECLARACION_PUBLICA",   "label": "Declaración pública" },
    { "id": "DENUNCIA_ACUSACION",    "label": "Denuncia o acusación" },
    { "id": "FILTRACION",            "label": "Filtración" },
    { "id": "DESMENTIDO",            "label": "Desmentido" },
    { "id": "EVENTO_GENERICO",       "label": "Evento genérico" }
  ],

  "extraction": {
    "models": {
      "extractor":  { "model": "llama3.1",  "role": "Extracción ontológica desde noticias." },
      "resolver":   { "model": "qwen3.5",   "role": "Detección de contradicciones entre eventos." },
      "auditor":    { "model": "claude",     "role": "Análisis complejo. Uso puntual vía API." }
    },
    "output_language": "es",
    "rules": [
      "Extraer el EVENTO principal: un hecho discreto con id kebab-case, nombre en español, event_type y fecha.",
      "Extraer ACTORES involucrados con id, nombre, tipo (Person/Organization/Location/Object) y descriptor breve.",
      "Para cada actor, indicar su ROL en el evento: el verbo que describe su participación (ej: 'se disculpa', 'sanciona', 'ataca', 'declara').",
      "Extraer relaciones estructurales entre actores (PERTENECE_A, UBICADO_EN).",
      "Si hay duda o versiones conflictivas: is_disputed = true en el evento.",
      "Mantener evidence_quote en el idioma original de la fuente.",
      "Nombres propios se mantienen en su forma original. Nombres genéricos en español.",
      "Los roles (verbos) SIEMPRE en español."
    ]
  }
}
